# Local development environment variables for Cloudflare Pages / wrangler
# Copy this file to .dev.vars and fill in your real values.
# .dev.vars is git-ignored and NEVER committed to version control.
#
# Usage:
#   cp .dev.vars.example .dev.vars
#   # edit .dev.vars and paste your real key
#   wrangler pages dev static

ANTHROPIC_API_KEY=sk-ant-your-key-here
